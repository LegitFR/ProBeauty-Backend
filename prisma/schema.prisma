generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  phone         String?
  role          String
  createdAt     DateTime       @default(now()) @map("created_at")
  isActive      Boolean        @default(false) @map("is_active")
  lastLogin     DateTime?      @map("last_login")
  otp           String?
  otpExpiresAt  DateTime?      @map("otp_expires_at")
  otpVerified   Boolean        @default(false) @map("otp_verified")
  password      String?
  refreshToken  String?        @map("refresh_token")
  authProvider  String         @default("local") @map("auth_provider")
  googleId      String?        @unique @map("google_id")
  addresses     Address[]
  bookings      Booking[]
  cart          Cart?
  deviceTokens  DeviceToken[]
  favourites    Favourite[]
  notifications Notification[]
  orders        Order[]
  reviews       Review[]
  staffReviews  StaffReview[]
  ownedSalons   Salon[]
  staffProfiles Staff[]

  @@map("users")
}

model Salon {
  id        String    @id @default(cuid())
  ownerId   String    @map("owner_id")
  name      String
  address   String
  geo       Json?
  hours     Json?
  verified  Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at")
  thumbnail String?
  images    String[]
  venueType String    @default("everyone") @map("venue_type")
  bookings  Booking[]
  orders    Order[]
  products  Product[]
  reviews   Review[]
  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  services  Service[]
  staff     Staff[]
  offers    Offer[]

  @@index([ownerId])
  @@map("salons")
}

model Staff {
  id             String         @id @default(cuid())
  salonId        String         @map("salon_id")
  userId         String?        @map("user_id")
  availability   Json?
  name           String
  image          String?
  averageRating  Float?         @map("average_rating")
  totalRatings   Int            @default(0) @map("total_ratings")
  bookings       Booking[]
  salon          Salon          @relation(fields: [salonId], references: [id], onDelete: Cascade)
  user           User?          @relation(fields: [userId], references: [id])
  services       StaffService[]
  reviews        StaffReview[]

  @@index([salonId])
  @@map("staff")
}

model Service {
  id              String         @id @default(cuid())
  salonId         String         @map("salon_id")
  title           String
  durationMinutes Int            @map("duration_minutes")
  price           Decimal        @db.Decimal(10, 2)
  category        String?
  image           String?
  bookings        Booking[]
  reviews         Review[]
  salon           Salon          @relation(fields: [salonId], references: [id], onDelete: Cascade)
  staff           StaffService[]
  offers          Offer[]

  @@index([salonId])
  @@index([category])
  @@map("services")
}

model Product {
  id         String      @id @default(cuid())
  salonId    String      @map("salon_id")
  title      String
  sku        String      @unique
  price      Decimal     @db.Decimal(10, 2)
  quantity   Int
  images     String[]
  cartItems  CartItem[]
  favourites Favourite[]
  orderItems OrderItem[]
  salon      Salon       @relation(fields: [salonId], references: [id], onDelete: Cascade)
  reviews    Review[]
  offers     Offer[]

  @@index([salonId])
  @@map("products")
}

model Booking {
  id           String        @id @default(cuid())
  userId       String        @map("user_id")
  salonId      String        @map("salon_id")
  serviceId    String        @map("service_id")
  staffId      String?       @map("staff_id")
  startTime    DateTime      @map("start_time")
  endTime      DateTime      @map("end_time")
  status       String
  salon        Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)
  service      Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff        Staff?        @relation(fields: [staffId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments     Payment[]
  staffReviews StaffReview[]

  @@index([userId])
  @@index([salonId])
  @@index([serviceId])
  @@index([staffId])
  @@index([startTime])
  @@map("bookings")
}

model Order {
  id         String      @id @default(cuid())
  userId     String      @map("user_id")
  salonId    String?     @map("salon_id")
  total      Decimal     @db.Decimal(10, 2)
  status     String
  createdAt  DateTime    @default(now()) @map("created_at")
  orderItems OrderItem[]
  salon      Salon?      @relation(fields: [salonId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments   Payment[]

  @@index([userId])
  @@index([salonId])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String  @map("order_id")
  productId String  @map("product_id")
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Payment {
  id               String    @id @default(cuid())
  orderId          String?   @map("order_id")
  provider         String
  amount           Decimal   @db.Decimal(10, 2)
  status           String
  txnId            String    @map("txn_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  failureReason    String?   @map("failure_reason")
  metadata         Json?
  stripeCustomerId String?   @map("stripe_customer_id")
  stripeEventId    String?   @unique @map("stripe_event_id")
  updatedAt        DateTime? @updatedAt @map("updated_at")
  bookingId        String?   @map("booking_id")
  booking          Booking?  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  order            Order?    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([bookingId])
  @@index([txnId])
  @@index([stripeEventId])
  @@map("payments")
}

model Review {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  salonId   String   @map("salon_id")
  serviceId String?  @map("service_id")
  productId String?  @map("product_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([salonId])
  @@index([serviceId])
  @@index([productId])
  @@map("reviews")
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique @map("user_id")
  createdAt DateTime   @default(now()) @map("created_at")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cartItems CartItem[]

  @@map("cart")
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String  @map("cart_id")
  productId String  @map("product_id")
  quantity  Int
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

model Offer {
  id String @id @default(cuid())

  // Ownership & Scope
  salonId   String  @map("salon_id")
  productId String? @map("product_id")
  serviceId String? @map("service_id")

  // Offer details
  title         String
  description   String?
  offerType     String  @map("offer_type")
  discountType  String  @map("discount_type") // percentage | flat
  discountValue Decimal @db.Decimal(10, 2)

  // Validity
  startsAt DateTime @map("starts_at")
  endsAt   DateTime @map("ends_at")
  isActive Boolean  @default(true) @map("is_active")

  // Media
  image String? // banner / poster image

  // Meta
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  salon   Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([salonId])
  @@index([productId])
  @@index([serviceId])
  @@index([isActive])
  @@index([startsAt, endsAt])
  @@map("offers")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("notifications")
}

model Address {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  fullName     String   @map("full_name")
  phone        String
  addressLine1 String   @map("address_line1")
  addressLine2 String?  @map("address_line2")
  city         String
  state        String
  postalCode   String   @map("postal_code")
  country      String
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  addressType  String   @default("Home") @map("address_type")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

model StaffReview {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  staffId   String   @map("staff_id")
  bookingId String   @map("booking_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([userId, staffId])
  @@index([userId])
  @@index([staffId])
  @@index([bookingId])
  @@map("staff_reviews")
}

model StaffService {
  id        String   @id @default(cuid())
  staffId   String   @map("staff_id")
  serviceId String   @map("service_id")
  createdAt DateTime @default(now()) @map("created_at")
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, serviceId])
  @@index([staffId])
  @@index([serviceId])
  @@map("staff_services")
}

model Favourite {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("favourites")
}

model DeviceToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  fcmToken  String    @map("fcm_token")
  platform  String
  isActive  Boolean   @default(true) @map("is_active")
  lastSeen  DateTime? @map("last_seen")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([fcmToken])
  @@index([isActive])
  @@map("device_tokens")
}
