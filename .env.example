PORT=8000

DATABASE_URL=postgresql://./test.db

ACCESS_SECRET_KEY=your_secret_key
REFRESH_SECRET_KEY=your_refresh_secret_key

NODE_ENV=development

EMAIL_USERNAME=user@email.com
EMAIL_PASSWORD=your_password
EMAIL_HOST=smtp.email.com
EMAIL_PORT=587

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# IfThenPay Configuration
IFTHENPAY_CCARD_KEY=your_ifthenpay_ccard_key
IFTHENPAY_MBWAY_KEY=your_ifthenpay_mbway_key
IFTHENPAY_ANTI_PHISHING_KEY=your_ifthenpay_anti_phishing_key
IFTHENPAY_USE_SANDBOX=false

# Vendus Configuration
VENDUS_API_KEY=your_vendus_api_key
VENDUS_BASE_URL=https://www.vendus.pt/ws/v1.1
VENDUS_DOCUMENT_TYPE=FS
VENDUS_MODE=normal

BACKEND_PUBLIC_URL=http://localhost:8000
FRONTEND_APP_URL=http://localhost:3000
