# ==============================================
# ProBeauty Backend - Docker Environment Config
# ==============================================
# NOTE: This is for reference only when using docker-compose.local-db.yml
# If you're using docker-compose.yml (default), use your existing .env file

# Application Settings
NODE_ENV=development
PORT=5000

# ==============================================
# OPTION 1: Using External Database (Default)
# ==============================================
# If you have an existing PostgreSQL database, just use your current .env file
# The default docker-compose.yml will use DATABASE_URL from your .env
# Example DATABASE_URL formats:
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname?schema=public
# DATABASE_URL=postgresql://user:password@your-db-host.com:5432/dbname?schema=public

# ==============================================
# OPTION 2: Using Local Docker Database
# ==============================================
# Only use these if running: docker-compose -f docker-compose.local-db.yml up
# PostgreSQL Database Configuration (Local Container)
POSTGRES_USER=probeauty
POSTGRES_PASSWORD=probeauty_dev_password_change_in_production
POSTGRES_DB=probeauty_db
POSTGRES_PORT=5432

# Database Connection URL (Auto-configured in docker-compose.local-db.yml)
# This will be overridden by docker-compose to point to the postgres service
# DATABASE_URL=postgresql://probeauty:probeauty_dev_password_change_in_production@postgres:5432/probeauty_db?schema=public

# JWT Secret Keys (MUST CHANGE IN PRODUCTION)
ACCESS_SECRET_KEY=your-super-secret-access-key-min-32-chars-long-change-this
REFRESH_SECRET_KEY=your-super-secret-refresh-key-min-32-chars-long-change-this

# Email Configuration (SMTP)
EMAIL_USERNAME=your-email@example.com
EMAIL_PASSWORD=your-email-password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# pgAdmin Configuration (Optional - for database management UI)
PGADMIN_EMAIL=admin@probeauty.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ==============================================
# Production Environment Variables
# ==============================================
# For production, use strong passwords and keep them secure
# Consider using Docker secrets or environment-specific .env files

# Example Production Settings:
# NODE_ENV=production
# POSTGRES_PASSWORD=<strong-random-password>
# ACCESS_SECRET_KEY=<strong-random-key-64-chars>
# REFRESH_SECRET_KEY=<strong-random-key-64-chars>
